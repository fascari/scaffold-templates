{% if include_db -%}
#!/bin/bash
set -e

# Creates the database and schema.
# Idempotent - safe to run multiple times.
# Reads DB credentials from .env or uses defaults.

# Load .env if it exists
if [ -f .env ]; then
  export $(grep -v '^#' .env | xargs)
fi

# Default values
DB_USER="${DB_USER:-{{ project_name }}_user}"
DB_PASSWORD="${DB_PASSWORD:-{{ project_name }}_pass}"
DB_NAME="${DB_NAME:-{{ project_name }}_db}"
DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-15432}"

# Wait for postgres to be ready
echo "Waiting for PostgreSQL..."
until PGPASSWORD="$DB_PASSWORD" psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d postgres -c '\q' 2>/dev/null; do
  sleep 2
done

# Create database if it doesn't exist
PGPASSWORD="$DB_PASSWORD" psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d postgres <<-EOSQL
    SELECT 'CREATE DATABASE $DB_NAME'
    WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = '$DB_NAME')\gexec
EOSQL

# Create schema if it doesn't exist
PGPASSWORD="$DB_PASSWORD" psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" <<-EOSQL
    CREATE SCHEMA IF NOT EXISTS public;
EOSQL

echo "Database and schema ready. Run 'mise run db:migrate' to apply migrations."
{% endif -%}
