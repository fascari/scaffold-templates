package bootstrap

import (
	"context"
	"fmt"
	"log/slog"
	"net/http"
	"time"
{% if include_db %}

	"gorm.io/gorm"
{% endif %}
{% if include_grpc %}

	"google.golang.org/grpc"
{% endif %}

	"{{ module_path }}/internal/config"

	"github.com/go-chi/chi/v5"
)

// App holds the application state and dependencies.
type App struct {
	config *config.Config
	logger *slog.Logger
{% if include_db %}
	db     *gorm.DB
{% endif %}
	router chi.Router
	server *http.Server
{% if include_grpc %}
	grpcServer *grpc.Server
{% endif %}
}

// New creates and initializes a new application instance.
func New(ctx context.Context, cfg *config.Config, logger *slog.Logger) (*App, func(), error) {
	app := &App{
		config: cfg,
		logger: logger,
	}

	cleanupFuncs := []func(){}
{% if include_otel %}

	// Setup telemetry
	if cfg.OTel.Enabled {
		shutdownOTel, err := setupTelemetry(ctx, cfg)
		if err != nil {
			return nil, nil, fmt.Errorf("setup telemetry: %w", err)
		}
		cleanupFuncs = append(cleanupFuncs, shutdownOTel)
	}
{% endif %}
{% if include_db %}

	// Setup database
	db, err := NewDB(ctx, cfg)
	if err != nil {
		return nil, nil, fmt.Errorf("setup database: %w", err)
	}
	app.db = db
	cleanupFuncs = append(cleanupFuncs, func() {
		if sqlDB, err := db.DB(); err == nil {
			_ = sqlDB.Close()
		}
	})
{% endif %}

	// Setup HTTP router
{% if include_db %}
	app.router = NewRouter(logger, db)
{% else %}
	app.router = NewRouter(logger)
{% endif %}
	app.server = &http.Server{
		Addr:    fmt.Sprintf(":%d", cfg.HTTP.Port),
		Handler: app.router,
	}
{% if include_grpc %}

	// Setup gRPC server
	grpcServer, grpcCleanup := NewGRPCServer(cfg{% if include_otel %}, cfg.OTel.Enabled{% endif %})
	app.grpcServer = grpcServer
	cleanupFuncs = append(cleanupFuncs, grpcCleanup)
{% endif %}

	cleanup := func() {
		for i := len(cleanupFuncs) - 1; i >= 0; i-- {
			cleanupFuncs[i]()
		}
	}

	return app, cleanup, nil
}

// Run starts the HTTP server and blocks until context is cancelled.
func (a *App) Run(ctx context.Context) error {
	errChan := make(chan error, 1)

	// Start HTTP server
	go func() {
		a.logger.Info("starting HTTP server", "port", a.config.HTTP.Port)
		if err := a.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			errChan <- fmt.Errorf("http server error: %w", err)
		}
	}()
{% if include_grpc %}

	// Start gRPC server
	go func() {
		if err := startGRPCServer(a.grpcServer, a.config.GRPC.Port, a.logger); err != nil {
			errChan <- fmt.Errorf("grpc server error: %w", err)
		}
	}()
{% endif %}

	// Wait for context cancellation or error
	select {
	case <-ctx.Done():
		a.logger.Info("shutting down gracefully")
	case err := <-errChan:
		a.logger.Error("server error", "error", err)
		return err
	}

	// Graceful shutdown
	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	if err := a.server.Shutdown(shutdownCtx); err != nil {
		a.logger.Error("http server shutdown error", "error", err)
		return err
	}
{% if include_grpc %}

	a.grpcServer.GracefulStop()
{% endif %}

	a.logger.Info("shutdown complete")
	return nil
}
