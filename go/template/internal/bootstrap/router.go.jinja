package bootstrap

import (
	"log/slog"
	"net/http"

	"{{ module_path }}/internal/app/example"
	"{{ module_path }}/internal/kit/errorhandler"
	"{{ module_path }}/internal/middleware"

	"github.com/go-chi/chi/v5"
	chimiddleware "github.com/go-chi/chi/v5/middleware"
{% if include_otel %}
	"go.opentelemetry.io/contrib/instrumentation/net/http/otelhttp"
{% endif %}
{% if include_db %}
	"gorm.io/gorm"
{% endif %}
)

// NewRouter creates and configures the HTTP router with all routes and middleware.
{% if include_db %}
func NewRouter(logger *slog.Logger, db *gorm.DB) chi.Router {
{% else %}
func NewRouter(logger *slog.Logger) chi.Router {
{% endif %}
	r := chi.NewRouter()

	// Global middleware
	r.Use(errorhandler.Middleware(logger))
	r.Use(middleware.RequestID)
	r.Use(middleware.Logger(logger))
	r.Use(chimiddleware.Recoverer)
{% if include_otel %}
	r.Use(func(next http.Handler) http.Handler {
		return otelhttp.NewHandler(next, "http-server")
	})
{% endif %}

	// Health endpoint
	r.Get("/health", func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusOK)
		_, _ = w.Write([]byte(`{"status":"ok"}`))
	})

	// API routes
	r.Route("/v1", func(r chi.Router) {
		// Example domain
{% if include_db %}
		repo := example.NewGORMRepository(db)
{% else %}
		repo := example.NewInMemoryRepository()
{% endif %}
		svc := example.NewService(repo)
		handler := example.NewHandler(svc)
		r.Mount("/examples", handler.Routes())
	})

	return r
}
