{% if include_db %}
package database

import (
	"context"

	"gorm.io/gorm"
)

type txKey struct{}

// WithTX stores a transaction in the context for propagation through layers.
func WithTX(ctx context.Context, tx *gorm.DB) context.Context {
	return context.WithValue(ctx, txKey{}, tx)
}

// TXFromContext extracts a transaction from the context, or returns nil.
func TXFromContext(ctx context.Context) *gorm.DB {
	if tx, ok := ctx.Value(txKey{}).(*gorm.DB); ok {
		return tx
	}
	return nil
}
{% endif %}
