# Local development environment variables
# Copy to .env and fill in real values

# Application
APP_NAME={{ project_name }}
APP_ENV=development

# HTTP Server
HTTP_PORT=8080
{% if include_grpc -%}
GRPC_PORT=9090
{% endif %}

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
{% if include_db %}

# Database
DB_URL=postgres://{{ project_name }}_user:{{ project_name }}_pass@localhost:15432/{{ project_name }}_db?sslmode=disable&search_path=public
{% endif -%}
{% if include_otel %}

# OpenTelemetry
OTEL_ENABLED=true
OTEL_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME={{ project_name }}
{% endif -%}
