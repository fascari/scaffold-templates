# Local development environment variables.
# Copy to .env and fill in real values.

LOG_LEVEL=info
HTTP_PORT=8080

{% if include_db and db_engine == 'postgres' -%}
DATABASE_URL=postgres://{{ project_name }}:{{ project_name }}@localhost:5432/{{ project_name }}?sslmode=disable
{% elif include_db and db_engine == 'mysql' -%}
DATABASE_URL={{ project_name }}:{{ project_name }}@tcp(localhost:3306)/{{ project_name }}?parseTime=true
{% elif include_db and db_engine == 'sqlite' -%}
DATABASE_URL=file:./data/{{ project_name }}.db?cache=shared&mode=rwc
{%- endif %}
